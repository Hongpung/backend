{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "\\.e2e-spec\\.ts$",
  "setupFiles": ["<rootDir>/test/prisma/jest.e2e.env.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^@hongpung/redis$": "<rootDir>/src/infrastructure/redis/index.ts",
    "^@hongpung/redis/(.*)$": "<rootDir>/src/infrastructure/redis/$1"
  },
  "testTimeout": 120000
}
