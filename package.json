{
  "name": "hongpung-server",
  "version": "1.2.0",
  "description": "Hongpung Server",
  "author": "YunHo Kang",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "check:orphans": "knip --include files,exports",
    "check:orphans:files": "knip --include files",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "npm run db:test:migrate && cross-env E2E_TEST=1 INTEGRATION_TEST=1 jest --config ./test/jest-e2e.json --runInBand",
    "db:test:migrate": "ts-node test/prisma/migrate-test-database.ts",
    "test:integration": "npm run db:test:migrate && cross-env INTEGRATION_TEST=1 jest --config ./jest.integration.json --runInBand",
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.16",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.16",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.16",
    "@nestjs/platform-socket.io": "^11.0.16",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.1.3",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.0.16",
    "@prisma/adapter-mariadb": "6.19.3",
    "@prisma/client": "6.19.3",
    "@ptc-org/nestjs-query-core": "^9.1.0",
    "@ptc-org/nestjs-query-graphql": "^9.1.0",
    "async-mutex": "^0.5.0",
    "aws-sdk": "^2.1692.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.65.1",
    "class-validator": "^0.14.1",
    "dayjs": "^1.11.19",
    "es-hangul": "^2.3.2",
    "expo-server-sdk": "^3.14.0",
    "firebase": "^11.6.0",
    "firebase-admin": "^13.9.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "mariadb": "3.4.5",
    "nestjs-pino": "^4.6.1",
    "node-apn": "^3.0.0",
    "nodemailer": "^6.10.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.0.16",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.15.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.1",
    "@types/nodemailer": "^7.0.4",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "class-transformer": "^0.5.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "jest": "^29.7.0",
    "knip": "^5.88.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.5.3",
    "prisma": "6.19.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "\\.repository\\.integration\\.spec\\.ts$",
      "\\.handler\\.integration\\.spec\\.ts$",
      "\\.service\\.integration\\.spec\\.ts$"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1",
      "^@hongpung/redis$": "<rootDir>/../test/mocks/hongpung-redis.ts"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
