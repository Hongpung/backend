# Hongpung Server — copy to .env and fill in secrets
# docker compose up: Redis는 compose 내부 서비스(redis) — REDIS_HOST/PORT는 compose가 app에 주입함

# --- Docker images (GHCR pull) ---
# CI가 push한 태그와 맞출 것 (예: v1.2.0 태그 push → 1.2.0)
GHCR_OWNER=Hongpung
APP_IMAGE_TAG=1.2.0

# --- Database (외부 호스트 권장) ---
DATABASE_URL=mysql://user:password@db-host:3306/hongpung

# --- Redis ---
# docker compose (기본): compose.yml app.environment 이 redis / 6379 로 덮어씀 — .env에 적어도 됨
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# 호스트 Redis 또는 app network_mode: host 일 때만:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# --- JWT / Auth ---
SECRET_KEY=
ADMIN_SECRET_KEY=
VERIFIED_SECRET_KEY=
REFRESH_TOKEN_HASH_SECRET=

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
STORAGE_URL=

# --- Firebase ---
# 서비스 계정 JSON (docker compose: ./secret → /app/secret 마운트)
GOOGLE_APPLICATION_CREDENTIALS=secret/firestore/firebase-admin-sdk-key.json
# 또는 파일 없이: GOOGLE_APPLICATION_CREDENTIALS_JSON_BASE64=
FIREBASE_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_DB_URL=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MASSEGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MESUREMENT_ID=
# 세션 runtime 스냅샷 Firestore 경로 (미설정 시 session_snapshots / latest)
SESSION_SNAPSHOT_FIRESTORE_COLLECTION=session_snapshots
SESSION_SNAPSHOT_FIRESTORE_DOCUMENT=latest

# --- Mail ---
SMTP_EMAIL=
SMTP_PW=

# --- Metrics (Prometheus scrape / Basic Auth) ---
METRICS_USERNAME=
METRICS_PASSWORD=
# ENV_SCRAPE_TARGET=app:8080

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# --- Expo version API (optional) ---
EXPO_TOKEN=
EXPO_APP_ID=
EXPO_CHANNEL=production

# --- APNs Live Activity (production 필수) ---
# APNS_KEY_PATH=secret/apns/prod/AuthKey_XXXXX.p8
# APNS_KEY_ID=
# APNS_TEAM_ID=

NODE_ENV=production
